{
  "name": "@reload-dev/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": { "types": "./src/index.ts", "import": "./src/index.ts" }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsdown src/index.ts --format esm",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@reload-dev/core": "workspace:*",
    "@reload-dev/sdk": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
