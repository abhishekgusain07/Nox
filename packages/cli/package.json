{
  "name": "@reload-dev/cli",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "bin": {
    "reload-dev": "./dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@reload-dev/sdk": "workspace:*",
    "commander": "^13.0.0",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.0"
  }
}
